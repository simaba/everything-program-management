{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/simaba/everything-program-management/schemas/raid-row.schema.json",
  "title": "RAID Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "status",
    "severity",
    "owner",
    "due_date",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(R|A|I|D)-\\d{4}$"
    },
    "type": {
      "type": "string",
      "enum": ["risk", "assumption", "issue", "dependency"]
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 120
    },
    "status": {
      "type": "string",
      "enum": ["open", "watch", "mitigating", "blocked", "closed"]
    },
    "severity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "owner": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "impact": {
      "type": "string",
      "maxLength": 300
    },
    "mitigation": {
      "type": "string",
      "maxLength": 300
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "linked_decision_id": {
      "type": "string",
      "pattern": "^DM-\\d{4}$"
    }
  }
}
