{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/simaba/everything-program-management/schemas/raid-row.schema.json",
  "title": "RAID Row",
  "description": "Compatibility copy of raid-row.schema.json. One decision-support record for a risk, assumption, issue, or dependency.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "description",
    "category",
    "owner",
    "opened",
    "due",
    "status",
    "last_updated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RAID-[0-9]{4}$",
      "description": "Stable zero-padded identifier, for example RAID-0017."
    },
    "type": {
      "type": "string",
      "enum": ["risk", "assumption", "issue", "dependency"]
    },
    "title": {"type": "string", "minLength": 5, "maxLength": 120},
    "description": {"type": "string", "minLength": 10, "maxLength": 1000},
    "category": {
      "type": "string",
      "enum": ["scope", "schedule", "cost", "quality", "resource", "external"]
    },
    "owner": {"type": "string", "minLength": 2, "maxLength": 120},
    "opened": {"type": "string", "format": "date"},
    "due": {"type": ["string", "null"], "format": "date"},
    "status": {
      "type": "string",
      "enum": ["open", "monitoring", "mitigating", "blocked", "accepted", "closed", "transferred"]
    },
    "last_updated": {"type": "string", "format": "date"},
    "probability": {"type": "integer", "minimum": 1, "maximum": 5},
    "impact": {"type": "integer", "minimum": 1, "maximum": 5},
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25,
      "description": "Ordinal ordering aid; must equal probability multiplied by impact."
    },
    "mitigation": {"type": "string", "minLength": 5, "maxLength": 500},
    "trigger": {"type": "string", "minLength": 5, "maxLength": 500},
    "validation_plan": {"type": "string", "minLength": 5, "maxLength": 500},
    "fix_plan": {"type": "string", "minLength": 5, "maxLength": 700},
    "eta": {"type": ["string", "null"], "format": "date"},
    "provider": {"type": "string", "minLength": 2, "maxLength": 120},
    "blocks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 2, "maxLength": 120}
    },
    "resolution": {"type": "string", "minLength": 5, "maxLength": 700},
    "supersedes": {"type": "string", "pattern": "^RAID-[0-9]{4}$"},
    "linked_decision_id": {"type": "string", "pattern": "^DM-[0-9]{4}$"},
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 40}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "risk"}}, "required": ["type"]},
      "then": {"required": ["probability", "impact", "score", "mitigation", "trigger"]}
    },
    {
      "if": {"properties": {"type": {"const": "assumption"}}, "required": ["type"]},
      "then": {"required": ["validation_plan"]}
    },
    {
      "if": {"properties": {"type": {"const": "issue"}}, "required": ["type"]},
      "then": {"required": ["fix_plan", "eta"]}
    },
    {
      "if": {"properties": {"type": {"const": "dependency"}}, "required": ["type"]},
      "then": {"required": ["provider", "blocks"]}
    },
    {
      "if": {
        "properties": {"status": {"enum": ["closed", "transferred"]}},
        "required": ["status"]
      },
      "then": {"required": ["resolution"]}
    }
  ]
}
