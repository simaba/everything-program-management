{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/simaba/everything-program-management/schemas/decision-memo-frontmatter.schema.json",
  "title": "Decision Memo Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "decider",
    "due",
    "status",
    "decided",
    "decision",
    "review_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^DM-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160
    },
    "decider": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "due": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "decided", "deferred", "superseded"]
    },
    "decided": {
      "type": ["string", "null"],
      "format": "date"
    },
    "decision": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 120
    },
    "review_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "decision_scope": {
      "type": "string",
      "minLength": 5,
      "maxLength": 300
    },
    "supersedes": {
      "type": "string",
      "pattern": "^DM-[0-9]{4}$"
    },
    "linked_raid_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^RAID-[0-9]{4}$"
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "decided"}}, "required": ["status"]},
      "then": {
        "properties": {
          "decided": {"type": "string", "format": "date"},
          "decision": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "if": {"properties": {"status": {"enum": ["draft", "in_review"]}}, "required": ["status"]},
      "then": {
        "properties": {
          "decided": {"type": "null"},
          "decision": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "deferred"}}, "required": ["status"]},
      "then": {
        "properties": {
          "decided": {"type": "null"},
          "decision": {"type": "string", "minLength": 5},
          "review_date": {"type": "string", "format": "date"}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "superseded"}}, "required": ["status"]},
      "then": {"required": ["supersedes"]}
    }
  ]
}
